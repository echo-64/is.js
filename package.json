{
  "name": "@echo-64/is.js",
  "version": "2.0.0",
  "description": "Semantic type checking for JavaScript.",
  "author": "𝖊𝖈𝖍𝖔 <https://github.com/echo-64>",
  "license": "MIT",
  "main": "./dist/is.cjs.min.js",
  "module": "./dist/is.esm.node.js",
  "browser": {
    "import": "./dist/is.esm.min.js",
    "default": "./dist/is.iife.min.js"
  },
  "types": "./dist/is.d.ts",
  "exports": {
    ".": {
      "require": "./dist/is.js",
      "import": "./dist/is.mjs",
      "types": "./dist/is.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/echo-64/is.js.git"
  },
  "bugs": {
    "url": "https://github.com/echo-64/is.js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "./dist",
    "./LICENSE",
    "./README.md",
    "./CHANGELOG.md",
    "./is.js.gif",
    "./package.json",
    "./package-lock.json"
  ],
  "keywords": [
    "type-checking",
    "type-validation",
    "semantic-validation",
    "type-integrity",
    "context-aware",
    "type-inference",
    "type-predicates",
    "javascript-utils",
    "fluent-api",
    "validation",
    "semantic",
    "typeof"
  ],
  "scripts": {
    "watch": "npx rollup -c -w",
    "clean": "rm -rf ./dist/*",
    "declaration": "npx tsc -p ./tsconfig.declaration.json",
    "build": "npm run clean && npx rollup -c && npm run declaration"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.4",
    "rollup-plugin-glob": "^1.0.2",
    "typescript": "^6.0.3"
  }
}
