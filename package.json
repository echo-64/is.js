{
  "name": "@echo-64/is.js",
  "version": "1.2.1",
  "description": "Tiny JS Type Checker Module for Node & Browser — Supports Stringified Types",
  "author": "𝖊𝖈𝖍𝖔 <https://github.com/echo-64>",
  "license": "MIT",
  "main": "./dist/is.js",
  "module": "./dist/is.mjs",
  "browser": "./dist/is.min.js",
  "types": "./dist/is.d.ts",
  "exports": {
    ".": {
      "require": "./dist/is.js",
      "import": "./dist/is.mjs",
      "types": "./dist/is.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/echo-64/is.js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "./dist",
    "./LICENSE",
    "./README.md",
    "./CHANGELOG.md",
    "./is.js.gif",
    "./package.json",
    "./package-lock.json"
  ],
  "keywords": [
    "check",
    "type-safe",
    "type-check"
  ],
  "scripts": {
    "watch": "npx rollup -c -w",
    "clean": "rm -rf ./dist/*",
    "declaration": "npx tsc -p ./tsconfig.declaration.json",
    "build": "npm run clean && npx rollup -c && npm run declaration"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.4",
    "rollup-plugin-glob": "^1.0.2",
    "typescript": "^6.0.3"
  }
}
